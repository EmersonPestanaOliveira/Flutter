rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, update, create: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /localidades/{localidadeId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /localidades/{localidadeId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && localidadeId == 'demo_times_square_public';
    }

    match /solicitacoes_localidade/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /ocorrencias/{ocorrenciaId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /ocorrencias_info/{infoId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /placas_solicitacoes/{solicitacaoId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /placas_info/{infoId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /cameras/{cameraId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.users is list
        && request.auth.uid in request.resource.data.users;
      allow delete: if false;
    }

    match /alertas/{alertaId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /videos/{videoId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid ||
          request.auth.uid in request.resource.data.users
        );
      allow delete: if false;
    }

    match /videos_ao_vivo/{videoId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /vinculos_localidades/{linkId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow write: if signedIn()
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
